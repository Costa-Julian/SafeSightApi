    {
      "name": "Seed ciudades (4 alertas + avistamientos)",
      "description": "Crea 4 alertas nuevas, una en cada ciudad (Rosario, Mar del Plata, Quilmes y Paraná/Entre Ríos), y cada una siembra automáticamente N avistamientos ('estoy enterado') dispersos ~±3 km alrededor del centro de la ciudad. N se controla con la variable de colección 'avistamientosPorAlerta' (default 100). Ejecutá los 4 requests (o corré la carpeta con el Runner). Mirá la consola de Postman (View → Show Postman Console) para el progreso.",
      "item": [
        {
          "name": "Rosario — alerta + avistamientos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const baseUrl = pm.collectionVariables.get('baseUrl');",
                  "const N = parseInt(pm.collectionVariables.get('avistamientosPorAlerta') || '100', 10);",
                  "const lat0 = -32.9442;  // centro de Rosario",
                  "const lon0 = -60.6505;",
                  "const ciudad = 'Rosario';",
                  "",
                  "const json = pm.response.json();",
                  "if (!json || !json.success || !json.data || !json.data.id) {",
                  "    console.error('No se pudo crear la alerta de ' + ciudad + '. Se aborta el seed.');",
                  "} else {",
                  "    const alertId = json.data.id;",
                  "    pm.collectionVariables.set('alertId', alertId);",
                  "    console.log('Alerta de ' + ciudad + ' creada: ' + alertId + '. Sembrando ' + N + ' avistamientos...');",
                  "    let ok = 0, fail = 0;",
                  "    const enviar = function (i) {",
                  "        if (i >= N) {",
                  "            console.log(ciudad + ': avistamientos OK=' + ok + ' FAIL=' + fail + ' (de ' + N + ').');",
                  "            pm.test(ciudad + ': ' + ok + '/' + N + ' avistamientos creados', function () {",
                  "                pm.expect(ok).to.be.at.least(N);",
                  "            });",
                  "            return;",
                  "        }",
                  "        const lat = lat0 + (Math.random() - 0.5) * 0.06;  // dispersion ~±3 km",
                  "        const lon = lon0 + (Math.random() - 0.5) * 0.06;",
                  "        pm.sendRequest({",
                  "            url: baseUrl + '/api/reports/awareness',",
                  "            method: 'POST',",
                  "            header: { 'Content-Type': 'application/json' },",
                  "            body: { mode: 'raw', raw: JSON.stringify({",
                  "                alertId: alertId,",
                  "                latitude: lat,",
                  "                longitude: lon,",
                  "                reportedAt: new Date().toISOString()",
                  "            }) }",
                  "        }, function (err, res) {",
                  "            if (!err && res && res.code === 200) { ok++; } else { fail++; }",
                  "            enviar(i + 1);",
                  "        });",
                  "    };",
                  "    enviar(0);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "firstName", "value": "María", "type": "text" },
                { "key": "lastName", "value": "Gómez", "type": "text" },
                { "key": "age", "value": "28", "type": "text" },
                { "key": "physicalDescription", "value": "Mujer de 1.65m, cabello castaño largo, campera de jean.", "type": "text" },
