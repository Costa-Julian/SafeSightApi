    {
      "name": "Reports",
      "description": "Gestión de reportes ciudadanos. Los reportes de awareness se almacenan en Cassandra. Los de tipo info también se sincronizan a MongoDB cada ~15 segundos.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Garantiza una alerta válida antes de cada request de reportes.",
              "// Si {{alertId}} está vacío o ya no existe en el servidor (sesión vieja o",
              "// seed reseteado), crea una alerta fresca y la guarda. Esto evita que los",
              "// reportes se 'peguen' a alertas viejas que ya habíamos creado.",
              "const baseUrl = pm.collectionVariables.get('baseUrl');",
              "const alertId = pm.collectionVariables.get('alertId');",
              "",
              "function crearAlertaFresca(done) {",
              "    const hace7dias = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();",
              "    pm.sendRequest({",
              "        url: baseUrl + '/api/alerts',",
              "        method: 'POST',",
              "        body: {",
              "            mode: 'formdata',",
              "            formdata: [",
              "                { key: 'firstName', value: 'Juan' },",
              "                { key: 'lastName', value: 'Pérez' },",
              "                { key: 'age', value: '35' },",
              "                { key: 'physicalDescription', value: 'Hombre de 1.75m, cabello castaño.' },",
              "                { key: 'situation', value: 'Visto por última vez en el centro de la ciudad.' },",
              "                { key: 'latitude', value: '-34.6037' },",
              "                { key: 'longitude', value: '-58.3816' },",
              "                { key: 'disappearanceDate', value: hace7dias },",
              "                { key: 'emitterId', value: '1' }",
              "            ]",
              "        }",
              "    }, function (err, res) {",
              "        if (!err && res.code === 201 && res.json().success) {",
              "            const nuevoId = res.json().data.id;",
              "            pm.collectionVariables.set('alertId', nuevoId);",
              "            console.log('Alerta fresca creada para el reporte:', nuevoId);",
              "        } else {",
              "            console.warn('No se pudo crear la alerta fresca automáticamente.');",
              "        }",
              "        done();",
              "    });",
              "}",
              "",
              "if (!alertId) {",
              "    crearAlertaFresca(function () {});",
              "} else {",
              "    // Verifica que la alerta todavía exista en el servidor.",
              "    pm.sendRequest(baseUrl + '/api/alerts/' + alertId, function (err, res) {",
              "        if (err || res.code === 404 || !(res.json() && res.json().success)) {",
              "            crearAlertaFresca(function () {});",
              "        } else {",
              "            console.log('Reutilizando alerta existente:', alertId);",
              "        }",
              "    });",
              "}"
            ]
          }
        }
      ],
