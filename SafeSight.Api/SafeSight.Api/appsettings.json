{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DatabaseSettings": {
    "MongoDb": {
      "ConnectionString": "mongodb://127.0.0.1:27017",
      "DatabaseName": "safesight"
    },
    "Cassandra": {
      "ContactPoints": [ "127.0.0.1" ],
      "LocalDatacenter": "datacenter1",
      "Port": 9042,
      "Keyspace": "safesight",
      "Username": "",
      "Password": ""
    }
  },
  "SyncSettings": {
    "HeatmapSyncIntervalSeconds": 15
  },
  "HeatmapSettings": {
    "InfoPointWeight": 3,
    "AwarenessPointWeight": 1
  },
  "SeedSettings": {
    "EnableSeedOnStartup": true
  },
  "PhotoSettings": {
    "MaxFileSizeMb": 5
  }
}
